# binding-factory.at — Compiler-grade binding generator
#
# Input:  SDK package name + API docs URL
# Output: Complete, tested, registered BindingTarget implementation
#
# Architecture: 7-stage compiler pipeline with formal AST coverage verification
#
#   Frontend → Semantic Analysis → Gap Debate → Codegen → Verification → Regression → Deliver
#   (lexing)   (type checking)     (group)      (emit)    (conformance)   (full suite)  (report)
#
# Uses: pipeline, fan-out, human-gate, debate (group chat), gates,
#       hooks, observability, metering, memory domains, feedback loops,
#       schemas, env, artifacts, depth

topology binding-factory : [pipeline, fan-out, human-gate, debate] {

  meta {
    version: "1.0.0"
    description: "Compiler-grade binding generator — npm install SDK, introspect types, map every AST concept, debate gap strategies, generate + verify binding"
    domain: "compiler"
    timeout: 30m
  }

  roles {
    frontend: "SDK installation, type introspection, and API doc ingestion — produces the capability IR"
    semantic-analyzer: "Formal AST-to-SDK mapping — every interface, every field, no gaps"
    sdk-specialist: "Deep knowledge of the target SDK's idioms, patterns, and limitations"
    binding-veteran: "Expert in existing agentopology bindings — knows what works"
    platform-expert: "Understands the target platform's runtime, config format, and constraints"
    codegen: "TypeScript code generation following binding contract"
    verifier: "Formal conformance checking — AST coverage matrix + example scaffolding"
    regressor: "Full test suite + type check — ensures nothing breaks"
    differ: "SDK version diffing — compares old vs new .d.ts types to produce a change set"
    patcher: "Surgical binding updates — patches existing binding code without full rewrite"
  }

  # ---------------------------------------------------------------------------
  # Schemas — formal types for inter-agent contracts
  # ---------------------------------------------------------------------------

  schemas {
    schema CapabilityIR {
      sdk-package: string
      sdk-version: string
      auth-methods: array of string
      completion-endpoint: string
      tool-use-support: boolean
      streaming-support: boolean
      structured-output: boolean
      thinking-support: boolean
      batch-support: boolean
      mcp-support: boolean
      ?caching-support: boolean
      ?rate-limit-headers: array of string
      exported-types: array of string
      exported-functions: array of string
      model-ids: array of string
    }

    schema ASTMappingRow {
      ast-type: string
      ast-field: string
      coverage: CoverageLevel
      sdk-method: string
      strategy: GapStrategy
      notes: string
    }

    schema CoverageLevel {
      value: string
    }

    schema GapStrategy {
      value: string
    }

    schema ConformanceResult {
      example-file: string
      files-generated: number
      all-non-empty: boolean
      type-check-pass: boolean
      missing-concepts: array of string
    }
  }

  # ---------------------------------------------------------------------------
  # Depth — adaptive complexity based on SDK maturity
  # ---------------------------------------------------------------------------

  depth {
    factors: [sdk-maturity, feature-count, platform-complexity]
    levels {
      level 1 {
        label: "minimal"
        omit: [gap-debate]
      }
      level 2 {
        label: "standard"
        omit: []
      }
      level 3 {
        label: "thorough"
        omit: []
      }
    }
  }

  # ---------------------------------------------------------------------------
  # Stage 1: FRONTEND — Install SDK + Introspect Types + Read Docs
  # ---------------------------------------------------------------------------

  agent sdk-installer {
    role: frontend
    model: opus
    phase: 1
    permissions: auto
    tools: [Read, Write, Bash, WebFetch, Glob, Grep]
    writes: ["workspace/capability-ir/", "domains/sdk-types/"]
    max-turns: 25
    timeout: 10m
    description: "Installs the target SDK, reads its .d.ts type definitions, fetches API docs, and produces a complete Capability IR"
    produces: [capability-ir-doc, sdk-types-cache]
    outputs: {
      status: complete | partial | failed
    }
    prompt {
      You are the Frontend stage of a compiler pipeline that generates agentopology bindings.

      ## Input
      You receive TWO inputs:
      1. An npm package name (e.g. "@google/generative-ai", "openai", "cohere-ai")
      2. An API documentation URL (optional — the SDK types are primary)

      ## Your Job

      ### Step 1: Install the SDK
      ```bash
      npm install <package-name> --save-dev
      ```
      Verify installation succeeded. Read package.json to confirm version.

      ### Step 2: Introspect SDK Types
      Find and read the TypeScript declaration files:
      ```
      node_modules/<package>/dist/index.d.ts
      node_modules/<package>/dist/**/*.d.ts
      node_modules/<package>/types/**/*.d.ts
      ```

      Extract EVERY exported symbol:
      - Interfaces and their fields (with types)
      - Classes and their methods (with signatures)
      - Type aliases
      - Enums
      - Function signatures
      - Constants

      This is the GROUND TRUTH. The .d.ts files define what the SDK actually supports,
      not what the docs claim.

      IMPORTANT: Cache the full .d.ts content into domains/sdk-types/ so that
      downstream agents (and retry loops) can read SDK types without re-installing.

      ### Step 3: Fetch API Documentation (if URL provided)
      Use WebFetch to read the API docs. Look for:
      - Features mentioned in docs but not in SDK types (beta/REST-only)
      - Code examples showing usage patterns
      - Rate limiting details, pricing tiers
      - Authentication flows

      Cache fetched docs into domains/api-docs/ for retry loop reuse.

      ### Step 4: Produce the Capability IR
      Write a structured document to workspace/capability-ir.md with:

      ```markdown
      # Capability IR: <SDK Name> v<version>

      ## Authentication
      - Methods: [list exact auth patterns from SDK]
      - Code: [exact constructor call]

      ## Completion/Chat Endpoint
      - Method signature: [exact function signature from .d.ts]
      - Request params: [every parameter with type]
      - Response shape: [every field with type]
      - Streaming variant: [if exists, exact method]

      ## Tool Use / Function Calling
      - Schema format: [exact TypeScript interface for tool definitions]
      - Execution flow: [how tool results get sent back]
      - Stop reason: [exact string/enum for tool_use stop]

      ## Model Parameters
      For each parameter, note: [param name in SDK] [type] [default if known]
      - temperature, topP, topK, maxTokens, stop, seed
      - thinking/reasoning mode (if supported)
      - structured output / JSON mode
      - system prompt format

      ## Streaming
      - Event types: [list all SSE event types]
      - Delta format: [exact delta object shape]

      ## Advanced Features
      - Batch/async endpoints
      - Caching / prompt caching
      - Rate limit headers
      - MCP / plugin support
      - Multi-modal support

      ## All Exported Types
      [Complete list of every exported interface/type/class/function from .d.ts]

      ## All Model IDs
      [Every model identifier found in SDK types, docs, or examples]
      ```

      Be EXHAUSTIVE. Every field you miss here becomes a gap in the final binding.

      ### Step 5: Update the Binding Registry
      Read domains/binding-registry.json (create if it doesn't exist).
      Add or update an entry for this SDK:
      {
        "<binding-name>": {
          "package": "<npm-package>",
          "version": "<installed-version>",
          "docsUrl": "<API_DOCS_URL if provided>",
          "changelogUrl": "<github-releases-url if detectable>",
          "lastBuilt": "<ISO timestamp>",
          "lastChecked": "<ISO timestamp>"
        }
      }
      Write back to domains/binding-registry.json.
    }
  }

  # ---------------------------------------------------------------------------
  # Stage 2: SEMANTIC ANALYSIS — Map Every AST Concept to SDK
  # ---------------------------------------------------------------------------

  agent ast-mapper {
    role: semantic-analyzer
    model: opus
    phase: 2
    permissions: auto
    tools: [Read, Write, Grep, Glob]
    reads: ["workspace/capability-ir/", "domains/sdk-types/"]
    writes: ["workspace/ast-mapping/"]
    max-turns: 20
    timeout: 10m
    description: "Reads the full AST type definitions and maps every single interface, field, and type to the target SDK"
    consumes: [capability-ir-doc, sdk-types-cache]
    produces: [ast-mapping-doc]
    input-schema {
      capability-ir: string
    }
    output-schema {
      total-concepts: integer
      native-count: integer
      partial-count: integer
      client-side-count: integer
      impossible-count: integer
    }
    outputs: {
      completeness: full | has-gaps
    }
    prompt {
      You are the Semantic Analysis stage. You perform FORMAL type-checking of the
      agentopology AST against the target SDK's capabilities.

      ## Input
      1. Read workspace/capability-ir.md (from Stage 1)
      2. Read src/parser/ast.ts (the COMPLETE AST — this is your type system)
      3. Read domains/sdk-types/ for the raw .d.ts files (ground truth)

      ## Your Job

      Create a COMPLETE mapping table. You MUST cover EVERY exported interface in ast.ts.
      Do not skip any. Do not summarize. Every row must be explicit.

      ### The AST Concepts (ALL of these must appear in your mapping)

      **Top-Level AST (TopologyAST interface — 30 fields):**
      topology, nodes, edges, depth, memory, batch, environments, triggers, hooks,
      settings, mcpServers, metering, skills, toolDefs, roles, context, env,
      providers, schedules, interfaces, defaults, schemas, extensions,
      observability, params, interfaceEndpoints, imports, includes, checkpoint, artifacts

      **Node Types (6 types):**
      OrchestratorNode, ActionNode, AgentNode, GateNode, HumanNode, GroupNode

      **AgentNode Fields (48 fields — THE critical mapping):**
      id, label, type, phase, model, permissions, prompt, tools, skills, reads, writes,
      disallowedTools, skip, behavior, invocation, retry (simple + RetryConfig), isolation,
      background, mcpServers, outputs, scale (ScaleDef), hooks (HookDef[]), role,
      description, maxTurns, sandbox, fallbackChain, timeout, onFail, temperature,
      maxTokens, topP, topK, stop, seed, thinking, thinkingBudget, outputFormat, logLevel,
      join, circuitBreaker (CircuitBreakerConfig), compensates, inputSchema, outputSchema,
      produces, consumes, variants (PromptVariant[]), rateLimit, extensions

      **Edge Fields (EdgeDef — 13 fields):**
      from, to, condition, maxIterations, per, isError, errorType, tolerance, race,
      wait, weight, reflection

      **Supporting Types:**
      ScaleDef, DepthDef, DepthLevel, TriggerDef, HookDef, SkillDef, ToolBlockDef,
      ScheduleJobDef, InterfaceDef, MeteringDef, SchemaType, SchemaFieldDef, SchemaDef,
      ReplayConfig, CheckpointDef, ArtifactDef, CircuitBreakerConfig, RetryConfig,
      PromptVariant, DefaultsDef, SecretRef, SensitiveValue, AuthDef, ProviderDef,
      ParamDef, InterfaceEndpoints, ImportDef, IncludeDef, ObservabilityCaptureConfig,
      ObservabilitySpanConfig, ObservabilityDef, TopologyMeta, OutputsMap, BaseNode

      ### Output Format

      Write to workspace/ast-mapping.md with coverage levels:
      - NATIVE: SDK has a direct API for this. Note the exact method/param.
      - PARTIAL: SDK supports it but with different semantics. Note the gap.
      - CLIENT-SIDE: SDK has no support. Must be implemented in the binding.
      - IMPOSSIBLE: Cannot be implemented (e.g., hardware-level isolation).

      COUNT every row. The total MUST match the number of concepts listed above.
      If any concept is missing, your output is WRONG.
    }
  }

  # ---------------------------------------------------------------------------
  # Stage 3: GAP DEBATE — Group chat to resolve every gap strategy
  # ---------------------------------------------------------------------------
  # Three perspectives debate each PARTIAL/CLIENT-SIDE/IMPOSSIBLE gap:
  # - SDK specialist knows what the SDK can actually do
  # - Binding veteran knows what patterns work in existing bindings
  # - Platform expert knows runtime constraints

  agent sdk-specialist {
    role: sdk-specialist
    model: opus
    phase: 3
    tools: [Read, Grep, Glob]
    description: "Argues for SDK-native solutions — knows every method and param the SDK exposes"
  }

  agent binding-veteran {
    role: binding-veteran
    model: opus
    phase: 3
    tools: [Read, Grep, Glob]
    description: "Argues from existing binding patterns — knows what worked for claude-code, codex, kiro"
  }

  agent platform-expert {
    role: platform-expert
    model: opus
    phase: 3
    tools: [Read, Grep, Glob]
    description: "Argues from platform runtime constraints — knows what the platform actually supports at deploy time"
  }

  group gap-debate {
    members: [sdk-specialist, binding-veteran, platform-expert]
    speaker-selection: round-robin
    max-rounds: 3
    termination: "All gaps have a resolved strategy with consensus"
    description: "Three-perspective debate on gap resolution — SDK native vs polyfill vs shim vs skip"
    timeout: 10m
  }

  # Agent that synthesizes the debate into the binding spec
  agent spec-writer {
    role: binding-veteran
    model: opus
    phase: 3.5
    permissions: auto
    tools: [Read, Write, Grep, Glob]
    reads: ["workspace/capability-ir/", "workspace/ast-mapping/", "domains/sdk-types/"]
    writes: ["workspace/binding-spec/"]
    max-turns: 20
    timeout: 10m
    consumes: [ast-mapping-doc]
    produces: [binding-spec-doc]
    description: "Synthesizes gap debate results into a deterministic binding specification"
    outputs: {
      verdict: ready | needs-research
    }
    prompt {
      You are the Spec Writer. You synthesize the gap debate into a DETERMINISTIC
      binding specification that the code generator can follow mechanically.

      ## Input
      1. Read workspace/capability-ir.md
      2. Read workspace/ast-mapping.md
      3. Read the gap debate results
      4. Read an existing binding for reference: src/bindings/claude-code.ts

      ## Gap Resolution Strategies

      For every row marked PARTIAL, CLIENT-SIDE, or IMPOSSIBLE in the ast-mapping:

      | Strategy | When to use | What gets generated |
      |----------|-------------|-------------------|
      | POLYFILL | Simple client-side feature (retry, circuit breaker, rate limit) | Inline helper function in the binding |
      | SHIM | Complex client-side feature (checkpoint, observability) | Separate generated file |
      | MAP | SDK has the feature but with different names/semantics | Translation function |
      | COMMENT | Feature exists but binding cannot control it | Comment in generated code |
      | SKIP | Fundamentally impossible for this platform | Console warning at scaffold time |

      ## Output: workspace/binding-spec.md

      Write the complete spec with:
      - Gap resolution table (every gap with strategy — informed by debate)
      - File architecture (every file the binding will generate)
      - Model mapping table (topology aliases to exact SDK model IDs)
      - Permission mapping table
      - Tool name mapping (if names differ)
      - Platform-specific considerations

      This document is the BLUEPRINT. If anything is ambiguous, the generated code
      will be wrong.
    }
  }

  # ---------------------------------------------------------------------------
  # Stage 4: CODEGEN — Generate the Complete Binding
  # ---------------------------------------------------------------------------

  agent code-generator {
    role: codegen
    model: opus
    phase: 4
    permissions: auto
    tools: [Read, Write, Edit, Bash, Glob, Grep]
    reads: ["workspace/binding-spec/", "domains/sdk-types/"]
    writes: ["workspace/generated-binding/"]
    max-turns: 40
    timeout: 20m
    consumes: [binding-spec-doc, sdk-types-cache]
    produces: [binding-source]
    description: "Generates the complete binding TypeScript file following the binding-spec blueprint"
    retry {
      max: 2
      backoff: linear
      interval: 5s
    }
    outputs: {
      status: compiled | type-errors | incomplete
    }
    prompt {
      You are the Code Generation stage. You produce the complete binding file.

      ## Input
      1. Read workspace/binding-spec.md — the BLUEPRINT (follow it exactly)
      2. Read src/bindings/types.ts — the BindingTarget interface
      3. Read src/bindings/claude-code.ts — the reference implementation pattern
      4. Read src/bindings/anthropic-sdk.ts — SDK-style reference (if making an SDK binding)
      5. Read src/parser/ast.ts — all AST types you must import
      6. Read domains/sdk-types/ for the raw .d.ts when you need exact signatures

      ## Output
      Generate a new file: src/bindings/<name>.ts

      ## Structure (follow claude-code.ts pattern exactly):
      1. Module docstring
      2. Import block — import every AST type you reference
      3. Helper functions (toTitle, escapeString, durationToMs, etc.)
      4. Model mapping function
      5. Permission mapping function
      6. Section generators — one function per concern:
         - generateAgents(ast), generateGates(ast), generateHooks(ast),
         - generateTools(ast), generateMemory(ast), generateSettings(ast),
         - generateMcpJson(ast), generateObservability(ast),
         - generateCheckpoint(ast), generateScheduler(ast),
         - generateMetering(ast), generateContext(ast), etc.
      7. Main scaffold() function that wires everything
      8. Export the BindingTarget object

      ## Code Quality:
      - TypeScript strict mode — no any, no implicit returns
      - Every AST field from the binding-spec must be handled
      - Use the strategy from binding-spec for each gap (POLYFILL/SHIM/MAP/COMMENT/SKIP)
      - Escape backticks, dollar signs, and backslashes in template literals
      - Handle null/undefined checks for optional AST fields

      ## Registration:
      After generating the binding file:
      1. Edit src/bindings/index.ts — add import and registry entry
      2. Run `npx tsc --noEmit` to verify zero type errors
      3. If type errors, fix them immediately and re-check

      ## Self-Check (INNER LOOP — do this before signaling done):
      ```bash
      npx tsc --noEmit 2>&1 | head -20
      ```
      If errors, fix and re-check up to 3 times. Do NOT signal "compiled"
      until tsc passes clean.
    }
  }

  # ---------------------------------------------------------------------------
  # Human-in-the-loop — approve binding before test suite
  # ---------------------------------------------------------------------------

  human binding-review {
    description: "Human reviews the generated binding source before running the full test suite"
    timeout: 1h
    on-timeout: skip
  }

  # ---------------------------------------------------------------------------
  # Gates
  # ---------------------------------------------------------------------------

  gates {
    gate type-and-coverage {
      after: code-generator
      before: binding-review
      run: "scripts/binding-gate.sh"
      checks: [tsc, ast-coverage, imports]
      retry: 2
      on-fail: bounce-back
      timeout: 2m
    }

    gate conformance-matrix {
      after: conformance-checker
      before: regression-guard
      run: "scripts/conformance-gate.sh"
      checks: [all-examples-scaffold, non-empty-files, no-collisions]
      retry: 1
      on-fail: bounce-back
      timeout: 3m
    }
  }

  # ---------------------------------------------------------------------------
  # Stage 5: VERIFICATION — Formal Conformance Check
  # ---------------------------------------------------------------------------

  agent conformance-checker {
    role: verifier
    model: opus
    phase: 5
    permissions: auto
    tools: [Read, Write, Bash, Glob, Grep]
    reads: ["workspace/ast-mapping/", "workspace/binding-spec/", "workspace/generated-binding/"]
    writes: ["workspace/conformance-report/"]
    max-turns: 20
    timeout: 10m
    consumes: [binding-source, ast-mapping-doc]
    produces: [conformance-report]
    description: "Formal verification — scaffolds every example .at file, validates output structure, checks AST coverage matrix"
    output-schema {
      examples-passed: integer
      examples-total: integer
      ast-coverage-pct: number
      missing-concepts: array of string
    }
    outputs: {
      verdict: pass | fail
    }
    prompt {
      You are the Verification stage. You perform FORMAL conformance checking.

      ## Step 1: AST Coverage Matrix
      Read src/parser/ast.ts and the new binding file.
      For every exported interface in ast.ts, grep the binding file for references.
      If ANY interface is unreferenced, mark it as a gap.

      ## Step 2: Scaffold Every Example
      For each .at file in examples/:
      ```bash
      npx tsx src/cli/index.ts scaffold <example.at> --target <binding-name> --dry-run
      ```
      Record: files generated, all non-empty, no path collisions.

      ## Step 3: Field-Level Coverage
      For AgentNode (48 fields), verify each field is handled in code, not just imported.

      ## Step 4: Edge Coverage
      Verify ALL edge types: standard, conditional, loop, error (-x->), fan-out,
      race, weighted, wait, tolerance, per-scoped, reflection.

      ## Step 5: Write Report
      Write workspace/conformance-report.md with full matrix and verdict.
    }
  }

  # ---------------------------------------------------------------------------
  # Stage 6: REGRESSION — Full Test Suite
  # ---------------------------------------------------------------------------

  agent regression-guard {
    role: regressor
    model: sonnet
    phase: 6
    permissions: auto
    tools: [Read, Write, Edit, Bash, Glob, Grep]
    reads: ["workspace/conformance-report/"]
    max-turns: 15
    timeout: 10m
    description: "Runs the complete test suite and type check to ensure nothing is broken"
    outputs: {
      verdict: pass | fail
    }
    prompt {
      You are the Regression Guard. You ensure the new binding doesn't break anything.

      1. `npx tsc --noEmit` — zero errors
      2. `npx vitest run` — ALL existing tests pass
      3. Verify binding registered in src/bindings/index.ts
      4. Validate all examples/ .at files
      5. Write new tests for the binding following existing patterns
      6. Run vitest again to confirm new tests pass
      7. Report final verdict: PASS or FAIL with details
    }
  }

  # ===========================================================================
  # UPDATE PATH — for when an SDK releases a new version
  # ===========================================================================
  #
  # Instead of regenerating from scratch, the update path:
  #   1. npm update the SDK
  #   2. Diff old vs new .d.ts types → produce a change set
  #   3. Diff old vs new capability IR → what capabilities changed?
  #   4. Patch the existing binding surgically (don't rewrite)
  #   5. Re-run conformance + regression (reuse existing pipeline)

  agent sdk-differ {
    role: differ
    model: opus
    phase: 1
    permissions: auto
    tools: [Read, Write, Bash, Glob, Grep]
    reads: ["domains/sdk-types/"]
    writes: ["workspace/sdk-diff/", "domains/sdk-types/"]
    max-turns: 20
    timeout: 10m
    description: "Updates SDK, diffs old vs new .d.ts types, produces a structured change set"
    outputs: {
      change-level: breaking | additive | patch | none
    }
    prompt {
      You are the SDK Differ. An SDK has been updated and you need to find what changed.

      ## Steps

      ### Step 0: Read the Binding Registry
      Read domains/binding-registry.json to find the package name, current version,
      docs URL, and changelog URL for the binding being updated.
      If a changelog URL exists, fetch it to understand what changed contextually.

      ### 1. Snapshot current types
      Read domains/sdk-types/ — these are the cached .d.ts files from the last build.
      Copy them to workspace/sdk-diff/old/ for comparison.

      ### 2. Update the SDK
      ```bash
      npm update <package-name>
      ```
      Read the new version from package.json.

      ### 3. Read new types
      Find and read the updated .d.ts files from node_modules/.
      Write them to domains/sdk-types/ (replacing the old cache).
      Also copy to workspace/sdk-diff/new/.

      ### 4. Produce the diff
      Compare old/ vs new/ and write workspace/sdk-diff/changeset.md:

      ```markdown
      # SDK Changeset: <package> v<old> → v<new>

      ## Summary
      - change-level: breaking | additive | patch | none
      - types-added: N
      - types-removed: N
      - types-modified: N
      - methods-added: N
      - methods-removed: N
      - params-changed: N

      ## Breaking Changes
      | Type/Method | Change | Impact on Binding |
      |------------|--------|-------------------|
      ...

      ## New Features
      | Type/Method | Description | AST Concept It Could Map To |
      |------------|-------------|---------------------------|
      ...

      ## Modified Signatures
      | Type/Method | Old Signature | New Signature |
      |------------|--------------|---------------|
      ...

      ## Removed
      | Type/Method | Replacement (if any) |
      |------------|---------------------|
      ...
      ```

      Be precise. Include exact type signatures, not descriptions.
    }
  }

  agent ir-updater {
    role: semantic-analyzer
    model: opus
    phase: 2
    permissions: auto
    tools: [Read, Write, Grep, Glob]
    reads: ["workspace/sdk-diff/", "workspace/capability-ir/"]
    writes: ["workspace/capability-ir/", "workspace/ast-mapping-delta/"]
    max-turns: 15
    timeout: 10m
    description: "Updates the capability IR and produces a delta mapping — only changed AST concepts"
    outputs: {
      status: updated | no-changes
    }
    prompt {
      You are the IR Updater. The SDK has been updated and you need to update the
      capability IR and identify which AST mappings changed.

      ## Steps

      ### 1. Read the changeset
      Read workspace/sdk-diff/changeset.md to understand what changed.

      ### 2. Update the capability IR
      Read workspace/capability-ir.md. For each change in the changeset:
      - New feature → add a new section to the IR
      - Removed feature → mark as removed in the IR
      - Modified signature → update the exact signatures

      Write the updated IR back to workspace/capability-ir.md.

      ### 3. Produce the AST mapping delta
      Read workspace/ast-mapping.md. For each change:
      - If a previously CLIENT-SIDE concept is now NATIVE → note the upgrade
      - If a previously NATIVE concept's API changed → note the migration
      - If a new SDK feature maps to an AST concept → note the new mapping

      Write workspace/ast-mapping-delta.md with ONLY the changed rows:

      ```markdown
      # AST Mapping Delta: <package> v<old> → v<new>

      ## Upgraded (CLIENT-SIDE → NATIVE/PARTIAL)
      | AST Concept | Old Coverage | New Coverage | New SDK Method |

      ## Migrated (signature changed)
      | AST Concept | Old SDK Method | New SDK Method | Breaking? |

      ## New Mappings
      | AST Concept | Coverage | SDK Method |

      ## Removed Mappings
      | AST Concept | Old SDK Method | Replacement |
      ```

      If nothing changed that affects AST mappings, report status: no-changes.
    }
  }

  agent binding-patcher {
    role: patcher
    model: opus
    phase: 3
    permissions: auto
    tools: [Read, Write, Edit, Bash, Glob, Grep]
    reads: ["workspace/sdk-diff/", "workspace/ast-mapping-delta/"]
    writes: ["workspace/generated-binding/"]
    max-turns: 30
    timeout: 15m
    retry {
      max: 2
      backoff: linear
      interval: 5s
    }
    description: "Surgically patches the existing binding — only modifies functions affected by the SDK change"
    outputs: {
      status: compiled | type-errors | no-changes
    }
    prompt {
      You are the Binding Patcher. You perform SURGICAL updates to an existing binding.

      ## CRITICAL: You do NOT rewrite the binding. You PATCH it.

      ## Steps

      ### 1. Read the delta
      Read workspace/sdk-diff/changeset.md and workspace/ast-mapping-delta.md.
      If the delta is empty (no AST mapping changes), report status: no-changes and stop.

      ### 2. Identify affected functions
      Read the existing binding file (e.g., src/bindings/vercel-ai.ts).
      For each changed AST mapping, find the generate*() function that handles it.
      List exactly which functions need patching.

      ### 3. Patch each function
      Use the Edit tool to make targeted changes:
      - Updated signatures → update the template literal that generates the SDK call
      - New features → add handling in the appropriate generate*() function
      - Removed features → update to use the replacement API or add a deprecation comment
      - Version bump → update the package.json generator's dependency versions

      ### 4. Self-check
      Run `npx tsc --noEmit` after each patch. Fix any type errors immediately.
      Do NOT proceed to the next patch until the current one compiles.

      ### 5. Final check
      Run `npx tsc --noEmit` one final time. Report status: compiled.
    }
  }

  # ---------------------------------------------------------------------------
  # Terminal actions
  # ---------------------------------------------------------------------------

  action deliver-binding {
    kind: report
    description: "Binding complete — compiled, tested, registered, and verified"
  }

  action deliver-update {
    kind: report
    description: "Binding updated — patched, tested, and verified against new SDK version"
  }

  # ---------------------------------------------------------------------------
  # Flow — Compiler pipeline with group debate + human gate + feedback loops
  # ---------------------------------------------------------------------------

  flow {
    # =======================================================================
    # CREATE PATH — full pipeline for new bindings
    # =======================================================================

    # Frontend: install + introspect
    sdk-installer -> ast-mapper

    # Semantic analysis feeds into group debate
    ast-mapper -> gap-debate

    # Debate results feed spec writer
    gap-debate -> spec-writer

    # Spec drives codegen
    spec-writer -> code-generator

    # Codegen -> human review (gate checks tsc first)
    code-generator -> binding-review

    # Human approves -> conformance check
    binding-review -> conformance-checker

    # Conformance -> regression
    conformance-checker -> regression-guard

    # Feedback loops — on failure, bounce back to codegen with error context
    conformance-checker -> code-generator    [when conformance-checker.verdict == fail, max 3]
    regression-guard -> code-generator       [when regression-guard.verdict == fail, max 3]

    # Terminal — binding delivered
    regression-guard -> deliver-binding      [when regression-guard.verdict == pass]

    # =======================================================================
    # UPDATE PATH — surgical patch for SDK version bumps
    # =======================================================================

    # Diff old vs new SDK types
    sdk-differ -> ir-updater

    # If no AST mapping changes, skip patching and go straight to regression
    ir-updater -> deliver-update             [when ir-updater.status == no-changes]

    # If changes exist, patch the binding
    ir-updater -> binding-patcher            [when ir-updater.status == updated]

    # Patched binding goes through the same verification pipeline
    binding-patcher -> conformance-checker

    # Feedback: conformance/regression failures bounce to patcher (not codegen)
    conformance-checker -> binding-patcher   [when conformance-checker.verdict == fail, max 2]
    regression-guard -> binding-patcher      [when regression-guard.verdict == fail, max 2]

    # Terminal — update delivered
    regression-guard -> deliver-update       [when regression-guard.verdict == pass]
  }

  # ---------------------------------------------------------------------------
  # Memory — structured workspace + domain cache for retry loops
  # ---------------------------------------------------------------------------

  memory {
    workspace {
      path: "workspace/"
      protocol: "workspace-protocol.md"
      structure: [capability-ir, ast-mapping, binding-spec, generated-binding, conformance-report, sdk-diff, ast-mapping-delta]
    }

    domains {
      path: "domains/"
      routing: "DOMAIN_MAP.md"
    }
  }

  # ---------------------------------------------------------------------------
  # Artifacts — lineage tracking for generated files
  # ---------------------------------------------------------------------------

  artifacts {
    artifact capability-ir-doc {
      type: markdown
      path: "workspace/capability-ir.md"
      retention: 30d
    }

    artifact sdk-types-cache {
      type: json
      path: "domains/sdk-types/"
      retention: 7d
    }

    artifact ast-mapping-doc {
      type: markdown
      path: "workspace/ast-mapping.md"
      retention: 30d
      depends-on: [capability-ir-doc]
    }

    artifact binding-spec-doc {
      type: markdown
      path: "workspace/binding-spec.md"
      retention: 30d
      depends-on: [ast-mapping-doc, capability-ir-doc]
    }

    artifact binding-source {
      type: json
      path: "workspace/generated-binding/"
      retention: 90d
      depends-on: [binding-spec-doc]
    }

    artifact conformance-report {
      type: markdown
      path: "workspace/conformance-report.md"
      retention: 30d
      depends-on: [binding-source, ast-mapping-doc]
    }

    artifact sdk-changeset {
      type: markdown
      path: "workspace/sdk-diff/changeset.md"
      retention: 30d
      depends-on: [sdk-types-cache]
    }

    artifact ast-mapping-delta {
      type: markdown
      path: "workspace/ast-mapping-delta.md"
      retention: 30d
      depends-on: [sdk-changeset, ast-mapping-doc]
    }

    artifact binding-registry {
      type: json
      path: "domains/binding-registry.json"
      retention: 365d
    }
  }

  # ---------------------------------------------------------------------------
  # Tools — gate scripts
  # ---------------------------------------------------------------------------

  tools {
    tool binding-gate {
      script: "scripts/binding-gate.sh"
      args: [binding-name]
      lang: bash
      description: "Type check + AST coverage verification for generated binding"
    }

    tool conformance-gate {
      script: "scripts/conformance-gate.sh"
      args: [binding-name]
      lang: bash
      description: "Scaffold all examples and verify output structure"
    }
  }

  # ---------------------------------------------------------------------------
  # Hooks — safety + observability events
  # ---------------------------------------------------------------------------

  hooks {
    hook guard-destructive {
      on: PreToolUse
      matcher: "Bash"
      run: "scripts/guard-destructive.sh"
      type: command
      timeout: 5000
    }

    hook log-stage-complete {
      on: AgentStop
      run: "scripts/log-stage.sh"
      type: command
    }

    hook cache-web-fetch {
      on: PostToolUse
      matcher: "WebFetch"
      run: "scripts/cache-fetch.sh"
      type: command
    }
  }

  # ---------------------------------------------------------------------------
  # Observability — trace the full pipeline
  # ---------------------------------------------------------------------------

  observability {
    enabled: true
    level: info
    exporter: stdout
    sample-rate: 1.0
    capture {
      prompts: false
      completions: false
      tool-args: true
      tool-results: true
    }
    spans {
      agents: true
      tools: true
      gates: true
      memory: true
    }
  }

  # ---------------------------------------------------------------------------
  # Metering — track cost per stage
  # ---------------------------------------------------------------------------

  metering {
    track: [tokens-in, tokens-out, cost, wall-time, agent-count]
    per: [agent, phase, run]
    output: "metrics/"
    format: jsonl
    pricing: anthropic-current
  }

  # ---------------------------------------------------------------------------
  # Defaults — all agents get thinking mode
  # ---------------------------------------------------------------------------

  defaults {
    thinking: high
    thinking-budget: 10000
    max-tokens: 16384
  }

  # ---------------------------------------------------------------------------
  # Environment variables
  # ---------------------------------------------------------------------------

  env {
    ANTHROPIC_API_KEY: sensitive "${ANTHROPIC_API_KEY}"
    NODE_ENV: "production"
  }

  # ---------------------------------------------------------------------------
  # Triggers
  # ---------------------------------------------------------------------------

  triggers {
    command build-binding {
      pattern: "/build-binding <SDK_PACKAGE> <API_DOCS_URL>"
      argument: SDK_PACKAGE
    }

    command build-binding-minimal {
      pattern: "/build-binding-fast <SDK_PACKAGE>"
      argument: SDK_PACKAGE
    }

    command update-binding {
      pattern: "/update-binding <BINDING_NAME>"
      argument: BINDING_NAME
    }
  }

  schedule {
    job check-sdk-updates {
      every: "monday 9:00"
      agent: sdk-differ
      enabled: true
    }
  }

  # ---------------------------------------------------------------------------
  # Settings — agents need filesystem access
  # ---------------------------------------------------------------------------

  settings {
    allow: ["Read", "Write", "Edit", "Glob", "Grep", "Bash", "WebFetch"]
    deny: ["Bash(rm -rf *)", "Bash(git push *)"]
    ask: ["Bash(npm install *)"]
  }

  # ---------------------------------------------------------------------------
  # Providers
  # ---------------------------------------------------------------------------

  providers {
    anthropic {
      api-key: "${ANTHROPIC_API_KEY}"
      models: [opus, sonnet, haiku]
      default: true
    }
  }
}
