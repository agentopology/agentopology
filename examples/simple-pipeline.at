# simple-pipeline.at — A basic 3-agent content pipeline
#
# Demonstrates: pipeline pattern, basic flow, gate, roles, triggers

topology simple-pipeline : [pipeline, human-gate] {

  meta {
    version: "1.0.0"
    description: "Research, write, and review — a minimal content pipeline"
  }

  orchestrator {
    model: sonnet
    generates: "commands/create.md"
    handles: [intake, done]
    outputs: {
      topic-type: technical | creative
    }
  }

  roles {
    researcher: "Gather information, find sources, and compile research notes"
    writer: "Draft content based on research, following style guidelines"
    reviewer: "Review drafts for accuracy, clarity, and completeness"
  }

  # --- Actions ---

  action intake {
    kind: inline
    description: "Parse user request — extract topic and requirements"
  }

  # --- Agents ---

  agent researcher {
    role: researcher
    model: gpt-4o
    permissions: supervised
    phase: 1
    tools: [Read, Grep, Glob, WebSearch]
    writes: ["workspace/research.md"]

    prompt {
        You are a research specialist focused on gathering comprehensive information.

        ## Guidelines
        - Search broadly for relevant sources
        - Compile findings into structured research notes
        - Include citations and source URLs
        - Prioritize recent and authoritative sources
    }
  }

  agent writer {
    role: writer
    model: sonnet
    permissions: autonomous
    phase: 2
    tools: [Read, Write, Glob]
    reads: ["workspace/research.md"]
    writes: ["workspace/draft.md"]
    outputs: {
      confidence: high | medium | low
    }

    prompt {
        You are a content writer who transforms research into polished drafts.

        ## Guidelines
        - Follow the style guide and tone requirements
        - Structure content with clear headings and sections
        - Incorporate all key findings from the research
        - Write for the target audience specified in the brief
    }
  }

  agent reviewer {
    role: reviewer
    model: opus
    permissions: supervised
    phase: 3
    tools: [Read, Grep, Glob]
    reads: ["workspace/draft.md", "workspace/research.md"]
    writes: ["workspace/review.md"]
    outputs: {
      verdict: approve | revise | reject
    }

    prompt {
        You are a content reviewer ensuring quality and accuracy.

        ## Guidelines
        - Verify all claims against the research sources
        - Check for clarity, grammar, and logical flow
        - Assess completeness against the original requirements
        - Provide actionable feedback for revisions if needed
    }
  }

  # --- Flow ---

  flow {
    intake -> researcher
    researcher -> writer
    writer -> reviewer
    reviewer -> writer     [when reviewer.verdict == revise, max 2]
    reviewer -> researcher [when reviewer.verdict == reject, max 1]
    reviewer -> done       [when reviewer.verdict == approve]
  }

  # --- Gates ---

  gates {
    gate quality-check {
      after: writer
      before: reviewer
      run: "scripts/check-quality.sh"
      checks: [grammar, formatting]
      on-fail: bounce-back
    }
  }

  # --- Action to finish ---

  action done {
    kind: report
    description: "Deliver final content to the user"
  }

  # --- Memory ---

  memory {
    workspace {
      path: "workspace/"
      structure: [research, drafts, reviews]
    }
  }

  # --- Triggers ---

  triggers {
    command create {
      pattern: "/create <TOPIC>"
      argument: TOPIC
    }
  }

  # --- Settings ---

  settings {
    allow: ["Read", "Grep", "Glob", "WebSearch"]
    deny: ["Bash(rm -rf *)"]
  }
}
